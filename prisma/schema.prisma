// =============================================================================
// Plantation Tracker — Prisma Schema
// =============================================================================
// Relational mapping of the 17-column official monthly proforma
// "০৫ বছরে ২৫ কোটি বৃক্ষ রোপণ কর্মসূচি"
//
// Tables:
//   Submission   — one per field-visit / form submit (parent)
//   Seedling     — repeatable species rows per submission (child 1:N)
//   Photo        — geo-verified evidence trail (child 1:N)
//   UserProfile  — Admin / Cadre / Monitoring Officer / SAAO / Citizen accounts
//   SeedSync     — Tracks when the workbook seed data was last pushed to DB
//
// For production, change the provider to "postgresql" and update
// DATABASE_URL in .env — the schema is provider-agnostic.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Main Submission (17-column proforma, one row per field visit) ──────────

model Submission {
  id        String   @id @default(cuid())
  clientUid String   @unique

  entryMode String   @default("dae_officer")

  // Location — report columns 2–6
  region   String   @default("")
  district String   @default("")
  upazila  String   @default("")
  union    String   @default("")
  blockId  String?
  blockName String?
  village  String   @default("")

  // Report column 9
  plantationDate String

  // Report column 10 — GPS
  latitude  Float    @default(0)
  longitude Float    @default(0)
  accuracy  Float    @default(0)

  // Report columns 11–12 — caretaker
  caretakerName    String @default("")
  caretakerMobile  String @default("")

  // Report columns 13–14 — SAAO
  saaoId     String?
  saaoName   String @default("")
  saaoMobile String @default("")

  // Report columns 15–16 — monitoring officer
  monitoringOfficerId     String?
  monitoringOfficerName   String @default("")
  monitoringOfficerMobile String @default("")

  // Report column 17
  remarks String?

  // App-only extras
  areaSqMeters  Float?
  spacingFlag   Boolean @default(false)

  nurserySourceId       String?
  nurserySourceName     String?
  nurserySourceLatitude  Float?
  nurserySourceLongitude Float?

  synced   Boolean  @default(true)
  syncedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seedlings Seedling[]
  photos    Photo[]

  @@index([district])
  @@index([upazila])
  @@index([synced])
  @@index([createdAt])
  @@index([plantationDate])
}

// ─── Seedling entries (report columns 7–8, repeatable per submission) ──────

model Seedling {
  id          String @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  plantTypeId String?
  speciesId   String?
  speciesName String
  count       Int    @default(0)

  @@index([submissionId])
  @@index([speciesName])
}

// ─── Photo evidence trail ──────────────────────────────────────────────────

model Photo {
  id                      String  @id @default(cuid())
  submissionId            String
  submission              Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  stage                   String  @default("planting")
  url                     String
  sha256                  String  @default("")
  capturedAt              String
  latitude                Float   @default(0)
  longitude               Float   @default(0)
  distanceFromOriginMeters Float?

  @@index([submissionId])
  @@index([stage])
}

// ─── User Profile ───────────────────────────────────────────────────────────
// Admin / Cadre / Monitoring Officer / SAAO / Citizen accounts.
//
// Bootstrap flow:
//   1. App install first time → fetches /api/auth/bootstrap (returns allow-list)
//   2. If the device's email (or user-entered email) matches an allow-list
//      entry → auto-creates a UserProfile row with the allow-list's role/name/
//      mobile/designation pre-populated.
//   3. If no match → user starts as 'citizen'. Name + Mobile are required
//      before any form submission (mandatory fields).
//   4. Optional fields (NID, JobID, designation, district, upazila) unlock
//      token-boost rewards via profileCompletionBonus.
//
// Idempotent upsert by `email` (unique). The allow-list lives in
// seed/admins.json so it can be updated without a migration.

model UserProfile {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String   @default("")
  mobile    String   @default("")

  // Role hierarchy: citizen < officer (SAAO) < cadre (monitoring officer) < admin
  role      String   @default("citizen")   // 'citizen' | 'officer' | 'cadre' | 'admin'

  // Optional identity fields — enhance token rewards when filled
  nid             String?   // National ID (10/13/17-digit BD format)
  jobId           String?   // DAE job ID (e.g. SAAO-12345)
  designation     String?   // 'SAAO' | 'UAO' | 'AEO' | 'AAO' | 'DDA' | 'Deputy Project Director'
  district        String?
  upazila         String?
  blockId         String?
  photoUrl        String?

  // Gamification state (mirrored from IndexedDB client-side)
  xp                      Int      @default(0)
  greenTokens             Int      @default(0)
  streakCount             Int      @default(0)
  profileCompletionBonus  Boolean  @default(false)

  // Bootstrap traceability
  bootstrapSource  String?  // 'allow-list' | 'manual' | 'admin-invite'
  invitedBy        String?  // email of the admin who invited (nullable for self-registered)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([district])
  @@index([upazila])
}

// ─── Seed Sync Tracking ─────────────────────────────────────────────────────
// Records each bulk-upsert of the workbook's "process data" sheet into the
// Submission table. Used by the Dashboard "Sync Seed Data" button to show
// the last sync time + record count + source workbook hash.

model SeedSync {
  id              String   @id @default(cuid())
  syncedAt        DateTime @default(now())
  recordCount     Int
  sourceFileName  String   @default("Tree_Plantation_Reporting_Workbook.xlsx")
  sourceFileHash  String   @default("")   // SHA-256 of the workbook file
  syncedByEmail   String?                 // which admin triggered the sync
  notes           String?

  @@index([syncedAt])
}