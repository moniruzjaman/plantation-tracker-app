{
  "name": "plantation-tracker-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moniruzjaman/plantation-tracker-app.git"
  },
  "bugs": {
    "url": "https://github.com/moniruzjaman/plantation-tracker-app/issues"
  },
  "homepage": "https://github.com/moniruzjaman/plantation-tracker-app#readme",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "build:web": "prisma generate && node download-and-process-logo.js && node map.js && vite build",
    "build:server": "prisma generate && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:assets": "node download-and-process-logo.js && node map.js",
    "build": "npm run build:web && npm run build:server",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:android": "npx cap open android",
    "android:prepare": "npm run build:web && npx cap sync android",
    "android:build": "node fix-gradle-wrapper.js && node chmod-gradlew.js && cd android && chmod +x gradlew && ./gradlew assembleDebug",
    "android:release": "node fix-gradle-wrapper.js && node chmod-gradlew.js && cd android && chmod +x gradlew && ./gradlew bundleRelease",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "@google/genai": "^2.10.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dexie": "^4.4.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "pngjs": "^7.0.0",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vercel": "^54.14.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
