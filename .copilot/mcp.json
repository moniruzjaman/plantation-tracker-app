/**
 * Safe MCP Pipeline — Plantation Tracker V1
 * Based on .copilot/mcp.json auto-pipeline (sanitized version)
 *
 * WHAT THIS DOES (safe):
 *   1. Install deps + audit fix
 *   2. Ensure required directories exist
 *   3. Initialize local SQLite database
 *   4. Generate auth.config.json (local only, no remote OAuth)
 *   5. Run lint / type-check
 *   6. Detect build target (APK vs PWA) and report
 *   7. Version bump in CHANGELOG.md (local only)
 *   8. Generate meta.html for social sharing (local only)
 *
 * WHAT WAS REMOVED (dangerous in original):
 *   - Vercel deploy (--prod --yes)
 *   - Git push / force push
 *   - README.md overwrite
 *   - Keystore generation with hardcoded passwords
 *   - GitHub release / gh CLI calls
 *   - Interactive readline self-improvement loop
 */

const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const ROOT = path.resolve('/home/z/my-project/plantation-tracker-v1');
const RESULTS = {};

function step(n, label, fn) {
  console.log(`\n${'='.repeat(60)}`);
  console.log(`STEP ${n}: ${label}`);
  console.log('='.repeat(60));
  try {
    const result = fn();
    RESULTS[`step${n}`] = { status: 'ok', detail: result || 'done' };
    console.log(`  ✅ ${label} — OK`);
  } catch (err) {
    RESULTS[`step${n}`] = { status: 'warn', detail: err.message?.substring(0, 200) };
    console.log(`  ⚠️  ${label} — ${err.message?.substring(0, 120)}`);
  }
}

function run(cmd, opts = {}) {
  return execSync(cmd, { cwd: ROOT, stdio: 'pipe', timeout: 120000, ...opts }).toString().trim();
}

console.log('🌱 Safe MCP Pipeline — Plantation Tracker V1');
console.log(`   Working dir: ${ROOT}\n`);

// ── Step 1: Install dependencies ──
step(1, 'Install dependencies & audit fix', () => {
  run('npm install 2>&1');
  return 'installed';
});

// ── Step 2: Ensure directories ──
step(2, 'Ensure required directories', () => {
  const dirs = ['assets', 'android/app/src/main/res', 'public'];
  const created = [];
  dirs.forEach(d => {
    const full = path.join(ROOT, d);
    if (!fs.existsSync(full)) {
      fs.mkdirSync(full, { recursive: true });
      created.push(d);
    }
  });
  return created.length ? `Created: ${created.join(', ')}` : 'All directories exist';
});

// ── Step 3: Initialize SQLite database ──
step(3, 'Initialize SQLite database', () => {
  let sqliteAvailable = false;
  try { require('better-sqlite3'); sqliteAvailable = true; } catch {}
  try { require('sqlite3'); sqliteAvailable = true; } catch {}

  if (!sqliteAvailable) {
    const schemaPath = path.join(ROOT, 'schema.sql');
    const schema = [
      '-- Plantation Tracker Schema (SQLite)',
      'CREATE TABLE IF NOT EXISTS plantations (',
      '  id INTEGER PRIMARY KEY AUTOINCREMENT,',
      '  name TEXT NOT NULL,',
      '  species TEXT,',
      '  date TEXT NOT NULL,',
      '  division TEXT,',
      '  district TEXT,',
      '  lat REAL,',
      '  lng REAL,',
      '  seedling_count INTEGER DEFAULT 0,',
      "  status TEXT DEFAULT 'active',",
      "  created_at TEXT DEFAULT (datetime('now'))",
      ');',
      '',
      'CREATE TABLE IF NOT EXISTS sync_queue (',
      '  id INTEGER PRIMARY KEY AUTOINCREMENT,',
      '  action TEXT NOT NULL,',
      '  payload TEXT,',
      "  status TEXT DEFAULT 'pending',",
      "  created_at TEXT DEFAULT (datetime('now'))",
      ');',
    ].join('\n');
    fs.writeFileSync(schemaPath, schema);
    return 'SQLite not in deps — schema written to schema.sql';
  }

  const sqlite3 = require('sqlite3').verbose();
  const dbPath = path.join(ROOT, 'app.db');
  const db = new sqlite3.Database(dbPath);
  db.serialize(() => {
    db.run('CREATE TABLE IF NOT EXISTS plantations (id INTEGER PRIMARY KEY, name TEXT, date TEXT, species TEXT, lat REAL, lng REAL)');
    db.run("CREATE TABLE IF NOT EXISTS sync_queue (id INTEGER PRIMARY KEY, action TEXT, payload TEXT, status TEXT DEFAULT 'pending')");
  });
  db.close();
  return `Database initialized at ${dbPath}`;
});

// ── Step 4: Generate auth.config.json (local only) ──
step(4, 'Generate auth.config.json', () => {
  const config = {
    provider: 'local',
    free: true,
    oauth: [],
    note: 'Local development mode — no remote OAuth configured'
  };
  fs.writeFileSync(path.join(ROOT, 'auth.config.json'), JSON.stringify(config, null, 2));
  return 'Written to auth.config.json';
});

// ── Step 5: Lint / type-check ──
step(5, 'Lint & type-check', () => {
  try {
    run('npx tsc --noEmit 2>&1', { timeout: 60000 });
    return 'No TypeScript errors';
  } catch (err) {
    const output = err.stdout?.toString() || err.message || '';
    const errorLines = (output.match(/error TS/g) || []).length;
    return `${errorLines} TS issue(s) found — non-blocking for dev`;
  }
});

// ── Step 6: Detect build target ──
step(6, 'Detect build target', () => {
  const hasGradlew = fs.existsSync(path.join(ROOT, 'android/gradlew'));
  const hasVite = fs.existsSync(path.join(ROOT, 'vite.config.ts'));
  const hasCapacitor = fs.existsSync(path.join(ROOT, 'capacitor.config.ts'));

  let target = 'UNKNOWN';
  if (hasGradlew && hasCapacitor) target = 'Hybrid: APK + PWA (Capacitor)';
  else if (hasGradlew) target = 'APK (Android/Capacitor)';
  else if (hasVite) target = 'PWA (Vite + React)';

  return `Target: ${target} | Vite: ${hasVite ? 'yes' : 'no'} | Capacitor: ${hasCapacitor ? 'yes' : 'no'}`;
});

// ── Step 7: Version bump in CHANGELOG ──
step(7, 'Version bump (local only)', () => {
  const changelogPath = path.join(ROOT, 'CHANGELOG.md');
  let version = 'v1.0.0';

  if (fs.existsSync(changelogPath)) {
    const content = fs.readFileSync(changelogPath, 'utf8');
    const match = content.match(/v(\d+)\.(\d+)\.(\d+)/);
    if (match) {
      version = `v${match[1]}.${match[2]}.${parseInt(match[3]) + 1}`;
    }
  }

  const entry = [
    '',
    `## ${version} — ${new Date().toISOString()}`,
    '- Pipeline: safe-mcp-pipeline executed',
    `- Build target: ${RESULTS.step6?.detail || 'N/A'}`,
    '- Dependencies: installed',
    '- DB schema: prepared',
    '- Auth config: generated (local mode)',
    ''
  ].join('\n');

  fs.appendFileSync(changelogPath, entry);
  return `Bumped to ${version} in CHANGELOG.md (local only)`;
});

// ── Step 8: Generate meta.html ──
step(8, 'Generate meta.html (social sharing)', () => {
  const meta = [
    '<!DOCTYPE html>',
    '<html lang="en">',
    '<head>',
    '  <meta charset="UTF-8">',
    '  <meta property="og:title" content="Plantation Tracker V1">',
    '  <meta property="og:description" content="Open-source plantation tracking PWA for Bangladesh forestry.">',
    '  <meta property="og:image" content="https://raw.githubusercontent.com/moniruzjaman/plantation-tracker-v1/main/public/og-image.png">',
    '  <meta property="og:url" content="https://github.com/moniruzjaman/plantation-tracker-v1">',
    '  <meta name="twitter:card" content="summary_large_image">',
    '  <title>Plantation Tracker V1</title>',
    '</head>',
    '<body>',
    '  <h1>Plantation Tracker V1</h1>',
    '  <p>Open-source, zero-cost plantation tracking app for Bangladesh.</p>',
    '</body>',
    '</html>'
  ].join('\n');
  fs.writeFileSync(path.join(ROOT, 'meta.html'), meta);
  return 'Written to meta.html';
});

// ── Summary ──
console.log('\n' + '═'.repeat(60));
console.log('PIPELINE SUMMARY');
console.log('═'.repeat(60));
Object.entries(RESULTS).forEach(([key, val]) => {
  const icon = val.status === 'ok' ? '✅' : '⚠️';
  console.log(`  ${icon} ${key}: ${val.detail}`);
});
console.log('═'.repeat(60));
console.log('\n✅ Safe pipeline complete. No remote operations performed.');
console.log('   No git push, no deploy, no README overwrite.');